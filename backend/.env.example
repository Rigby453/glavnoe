# Kaizen backend — пример переменных окружения.
# Скопируйте в .env и подставьте реальные значения. .env в git НЕ коммитится.

# --- База данных (Neon Postgres) ---
# DATABASE_URL — pooled-строка (рантайм). Хост содержит суффикс "-pooler",
# в query-параметрах добавьте pgbouncer и лимит соединений, например:
#   ?pgbouncer=true&connection_limit=10
# Pooled-соединение нужно, чтобы выдержать нагрузку serverless-инстансов.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DB?sslmode=require&pgbouncer=true&connection_limit=10

# DIRECT_URL — прямая строка (без "-pooler"). Prisma использует её ТОЛЬКО для
# миграций (prisma migrate / db push). В рантайме приложение ходит через DATABASE_URL.
DIRECT_URL=postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DB?sslmode=require

# (Опционально) Отдельная БД для тестов. Если задана — jest.setup.ts переключит
# DATABASE_URL на неё во время прогона тестов.
# DATABASE_URL_TEST=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DB_test?sslmode=require&pgbouncer=true

# --- AI-провайдер (вызывается только из backend/src/ai/) ---
# Если задан GEMINI_API_KEY → Gemini; иначе ANTHROPIC_API_KEY → Claude.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite
ANTHROPIC_API_KEY=

# --- Прочее ---
JWT_SECRET=
PORT=3000
NODE_ENV=development

# Разрешить POST /api/v1/subscription/dev-upgrade в production.
# Задать ALLOW_DEV_UPGRADE=1 на Render для тестирования AI до реальных платежей.
# НЕ задавать на боевом релизе — эндпоинт будет закрыт (403).
# ALLOW_DEV_UPGRADE=

# --- Email-доставка (Resend, ADR-059) ---
# Используется для писем сброса пароля (POST /api/v1/auth/forgot-password).
# Если RESEND_API_KEY не задан — dev/test-режим: код возвращается в ответе
# как dev_code (письмо не отправляется). Как только ключ задан — письмо
# отправляется реально и dev_code в ответе больше не раскрывается.
# RESEND_API_KEY=re_...
# RESEND_FROM — verified sender, напр. "Kaizen <noreply@yourdomain.com>"
# RESEND_FROM=
